# Organization name shown in UI for org-level auth options
# VITE_ORG_NAME=MyCompany

# Google Calendar OAuth client ID (enables org-level Google Calendar connect)
# Get it from https://console.cloud.google.com/apis/credentials
# VITE_GOOGLE_CLIENT_ID=

# Jira OAuth client ID (enables org-level Jira connect via OAuth PKCE)
# Register an OAuth 2.0 app at https://developer.atlassian.com/console/myapps/
# VITE_JIRA_CLIENT_ID=

# Jira OAuth client secret (server-side only, used for token refresh)
# JIRA_CLIENT_SECRET=
